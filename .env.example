# ============================================================
#  RAG Chatbot 設定ファイル(例)
#  このファイルを ".env" にコピーして編集してください。
#    cp .env.example .env
# ============================================================

# --- サーバ ---
# 0.0.0.0 にすると同じネットワークの他PCからアクセスできます。
# 自分のPCだけで使うなら 127.0.0.1 に変更してください。
HOST=0.0.0.0
# ポート番号。他のアプリと衝突する場合は変更してください(既定 8800)。
PORT=8800

# 【社内ネットワーク限定】true にすると、社内LAN(192.168.x.x / 10.x / 172.16-31.x の
# プライベートIP)・このPC・リンクローカルからのみアクセスを許可し、インターネット側の
# グローバルIPからの接続は 403 で拒否します。社外公開しない運用では true(既定)のまま。
# ※ 判定は接続元の実IPで行い、X-Forwarded-For 等のヘッダは信用しません(なりすまし対策)。
LAN_ONLY=true

# 【重要】標準のプライベートIP(10.x / 172.16〜31.x / 192.168.x)以外を社内で使っている
# 場合は、ここに許可するネットワークを CIDR で指定してください(カンマ区切り)。
# 例: 社内が 172.36.x.x の場合 → ALLOWED_CIDRS=172.36.0.0/16
#     (172.16〜31 以外の 172.x はプライベート扱いにならないため、指定しないと弾かれます)
ALLOWED_CIDRS=

# --- 簡易パスワード認証 ---
# 値を設定するとログイン画面が出ます。空にすると認証なし(ネットワーク内の誰でもアクセス可)。
# 【重要】Code(コーディングエージェント)はサーバ上でコマンド実行・ファイル変更ができるため、
# LANに公開する場合や Code を使う場合は必ずパスワードを設定してください。
CHAT_PASSWORD=

# セッションCookie署名用の秘密鍵。空なら自動生成して data/secret.key に保存します。
SECRET_KEY=

# --- Ollama (ローカルLLM) ---
OLLAMA_HOST=http://localhost:11434
# 既定の生成モデル。UIからも切り替えできます。
CHAT_MODEL=gemma3:27b
# 画像(スクショ)を貼り付けたときに使う Vision/OCR モデルの初期値(要 ollama pull)。
# 起動後は設定画面(⚙)の「画像認識モデル」からインストール済みモデルへ切り替えできます。
# Gemma 3 はマルチモーダルなのでチャットと同じモデルで兼用できます。
# 別にしたい例: qwen2.5vl:32b / llama3.2-vision / GLM-OCR
VISION_MODEL=gemma3:27b
# Code(コーディングエージェント)で使う既定モデル。空なら CHAT_MODEL を流用。
# コード/ツール操作に強い「ツール呼び出し対応」モデルを指定すると精度が大きく上がります
# (例: qwen3-coder)。非対応モデル(gemma3 等)でも本文のJSONを拾って動きますが、
# 計画承認やツール実行の確実性が落ちます。設定画面(⚙)の「Code用モデル」からも変更可。
CODE_MODEL=

# 1リクエストのコンテキスト長(トークン)。0=モデル既定(多くは4096)。
# 【重要】Code(コーディングエージェント)は、システム指示+ツール定義だけで約8千トークン
# の固定費がかかります。8192 以下だとすぐ「コンテキスト超過」になり、回答品質が大きく
# 落ちます(自動で文脈を切り詰めて続行はします)。Code を使うなら 16384 以上を推奨。
# 大きいほど VRAM/メモリを消費します(まず 16384、余裕があれば 32768)。
NUM_CTX=16384

# --- OCR (スキャン/画像PDF。既定OFF。テキスト層の無い"ページだけ"OCRする) ---
# 有効化すると、テキストの取れないPDFページを画像化してOCRします(日英対応)。
# 【重要】OCR_ENABLED=false のままだと、スキャンPDF(テキスト層なし)は本文0文字になり、
# インデックス作成時に「[skip] …(抽出テキストなし)」で除外されます。スキャン文書を
# 取り込みたいときは true にして、対象インデックスを「再構築」してください。
OCR_ENABLED=false
# エンジン: vlm(Ollamaのビジョンモデル・推奨/追加導入不要) または tesseract
OCR_ENGINE=vlm
# vlm用モデル(空なら VISION_MODEL を流用)。文書OCRは qwen2.5vl / GLM-OCR 等が高精度。
# 例: ollama pull qwen2.5vl   →   OCR_VLM_MODEL=qwen2.5vl
#     ollama pull glm-ocr     →   OCR_VLM_MODEL=glm-ocr
OCR_VLM_MODEL=
# ページのテキスト層がこの文字数未満なら「スキャン頁」とみなしOCRへ
OCR_MIN_CHARS=16
# tesseractエンジン時の言語(要: tesseract本体 + jpn/eng データ)
OCR_LANG=jpn+eng
# ページ→画像の解像度(高いほど精度↑/遅い)
OCR_DPI=200

# OCR API(/api/ocr)を VBA / Python から呼ぶときの簡易APIキー。
# CHAT_PASSWORD で認証を有効にしている場合、リクエストヘッダ X-API-Key にこの値を
# 入れれば、ログイン無しで /api/ocr を呼べます(空ならAPIキー認証は無効)。
OCR_API_KEY=

# --- 埋め込み (RAG用ベクトル化) ---
# sentence-transformers (既定) か ollama を選べます。
EMBED_BACKEND=sentence-transformers
# sentence-transformers の場合の既定モデル(日本語対応)。
# 既定の e5-base は精度重視。軽量・低メモリ優先なら multilingual-e5-small に変更可。
EMBED_MODEL=intfloat/multilingual-e5-base
# EMBED_BACKEND=ollama の場合は、ollama pull したモデル名(例: nomic-embed-text)を指定
#
# 【社内ネットワークで「SSL証明書エラー」や「Cannot send a request...」でインデックス作成が
#   失敗する場合】HuggingFace からのモデルDLがプロキシのTLS検査で弾かれています。対処:
#   (推奨) Ollama で埋め込み:  ollama pull nomic-embed-text
#          EMBED_BACKEND=ollama
#          EMBED_MODEL=nomic-embed-text
#   (別案) 社内ルートCA(.pem)を環境変数 SSL_CERT_FILE に設定してDLを通す
#   (別案) 別PCでモデルを事前DLし、そのフォルダのパスを EMBED_MODEL に指定(オフライン運用)
#   ※ 埋め込みモデルを変えたら、既存の参照資料は再インデックス(再作成)してください。

# --- RAG パラメータ ---
# 検索で取り込む参考チャンク数(アプリ既定と同じ 15。小さくすると速いが取りこぼしが増える)
RAG_TOP_K=15
CHUNK_SIZE=800
CHUNK_OVERLAP=120
# 文脈付き埋め込み(Contextual Embeddings の局所版)。true にすると各文書の主題をLLMが1〜2文
# 生成し、チャンクの埋め込みに前置きして検索精度を上げる(作成は遅くなる)。再構築で反映。
CONTEXTUAL_EMBEDDINGS=false
# 回答前リランク: 検索の上位候補を、回答生成の前に LLM が関連度で採点して並べ替える
# (検索精度↑だが、クエリごとに LLM 呼び出しが1回増えてやや遅くなる。即時反映。既定OFF)。
RERANK_ENABLED=false
# リランクに使うモデル(空なら既定モデルを流用)。例: RERANK_MODEL=qwen3-32b
RERANK_MODEL=

# --- 参照資料: 共有サーバフォルダ ---
# ファイルサーバ/NAS の共有フォルダを「フォルダを選んで追加」のクイックアクセスに
# 表示します(複数は ; 区切り)。登録しなくても、フォルダ選択画面のパス入力欄に
# UNC パスを直接入力すれば開けます。
# 例(Windows): SHARED_FOLDERS=\\fileserver\共有\設計資料;\\nas\docs
# 例(Linux/Mac): SHARED_FOLDERS=/mnt/share/docs
# 【重要】アクセス権は「このアプリを起動しているユーザー」のものが使われます。
#   - タスクスケジューラ/サービスで起動する場合、マップ済みドライブ(Z: 等)は
#     見えないことが多いため、UNC パス(\\server\share\...)での指定を推奨します。
#   - 認証が必要な共有は、起動ユーザーで一度エクスプローラから開く(資格情報を保存する)
#     か、ドメインアカウントで起動してください。
SHARED_FOLDERS=

# --- アップロード上限 (MB) ---
MAX_UPLOAD_MB=50

# --- データ保存先 ---
DATA_DIR=data

# --- 画面タイトル ---
APP_TITLE=社内文書アシスタント
